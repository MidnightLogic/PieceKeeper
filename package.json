{
  "name": "piecekeeper",
  "version": "1.0.1",
  "description": "Distribute secrets. Eliminate single points of failure.",
  "author": "MidnightLogic",
  "license": "MIT",
  "workspaces": ["packages/core", "packages/pwa"],
  "homepage": "https://midnightlogic.github.io/PieceKeeper/",
  "repository": {
    "type": "git",
    "url": "https://github.com/MidnightLogic/PieceKeeper.git"
  },
  "bugs": {
    "url": "https://github.com/MidnightLogic/PieceKeeper/issues"
  },
  "keywords": [
    "shamir",
    "secret-sharing",
    "cryptography",
    "pwa",
    "offline",
    "qr-code",
    "nfc",
    "aes-256-gcm",
    "argon2id",
    "single-file"
  ],
  "type": "module",
  "scripts": {
    "dev": "npm run dev --workspace=packages/pwa",
    "build": "npm run build --workspace=packages/core && npm run build --workspace=packages/pwa",
    "build:pwa": "npm run build --workspace=packages/pwa",
    "build:core": "npm run build --workspace=packages/core",
    "preview": "npm run preview --workspace=packages/pwa",
    "test": "npm run test --workspace=packages/core",
    "test:core": "npm run test --workspace=packages/core",
    "preview:tunnel": "npm run preview:tunnel --workspace=packages/pwa",
    "dev:tunnel": "npm run dev:tunnel --workspace=packages/pwa"
  },
  "devDependencies": {},
  "dependencies": {}
}